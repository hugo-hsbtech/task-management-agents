# Required for Claude Agent SDK
CLAUDE_CODE_OAUTH_TOKEN=your_anthropic_api_key_here

# Optional: for headless/CI Linear MCP auth (Phase 1 uses OAuth via mcp-remote per D-01)
# LINEAR_API_KEY=your_linear_api_key_here

# Phase 2: hsb-test-fixture GitHub repo URL — Builder + Git agent integration tests
# read this via os.environ.get("HSB_TEST_FIXTURE_URL"). Operator must own the repo
# (gh CLI authenticated with `repo` scope). See .planning/phases/02-core-execution-agents/02-FIXTURE-REPO.md
# HSB_TEST_FIXTURE_URL=https://github.com/<YOUR_GITHUB_USER>/hsb-test-fixture

# Optional: PAT for non-interactive GitHub auth. If set, `make auth-github`
# uses `gh auth login --with-token` instead of the interactive device flow.
# Token must have `repo` scope. Persisted to the hsb-gh-auth named volume.
# GITHUB_TOKEN=ghp_your_personal_access_token_here

# ---------------------------------------------------------------------------
# Runtime selection (Codex alt-runtime, see
# docs/superpowers/specs/2026-05-09-codex-oauth-alt-runtime-design.md)
# ---------------------------------------------------------------------------

# Pick the runtime per agent. Default "claude". Only the backlog agent is
# currently flippable; WIO is hard-blocked from "codex" until its stateful
# session has a Codex equivalent.
# HSB_RUNTIME_BACKLOG=claude   # or "codex"

# Required when any HSB_RUNTIME_<AGENT>=codex: path to the Codex auth dir
# (the directory `codex login` writes to). codex_guards.py validates this on
# CodexRuntime construction.
# CODEX_HOME=/root/.codex

# Optional: explicit path to the codex binary (else PATH lookup is used).
# CODEX_PATH_OVERRIDE=/usr/local/bin/codex

# ---------------------------------------------------------------------------
# Operational tuning
# ---------------------------------------------------------------------------

# main_orchestrator claim debounce in milliseconds. Default 200.
# HSB_CLAIM_DELAY_MS=200

# ---------------------------------------------------------------------------
# Test-only flags
# ---------------------------------------------------------------------------

# Opt in to the live Codex integration test (tests/integration/
# test_backlog_codex_live.py). Without this set, the test is skipped.
# Requires CODEX_HOME and HSB_RUNTIME_BACKLOG=codex to also be set.
# HSB_LIVE_CODEX=1

# ---------------------------------------------------------------------------
# Host-only — do NOT put in this file (which is loaded into the container)
# ---------------------------------------------------------------------------
# HSB_PROJECT scopes Docker Compose volumes/containers per org for multi-org
# isolation. It must be exported in your shell BEFORE invoking `make`, e.g.:
#   export HSB_PROJECT=org-acme
#   make auth-linear && make up
# Default: "task-management-agents". See scripts/_lib.sh.
