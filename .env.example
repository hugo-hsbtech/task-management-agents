# Required for Claude Agent SDK
CLAUDE_CODE_OAUTH_TOKEN=your_anthropic_api_key_here

# Optional: for headless/CI Linear MCP auth (Phase 1 uses OAuth via mcp-remote per D-01)
# LINEAR_API_KEY=your_linear_api_key_here

# Phase 2: hsb-test-fixture GitHub repo URL — Builder + Git agent integration tests
# read this via os.environ.get("HSB_TEST_FIXTURE_URL"). Operator must own the repo
# (gh CLI authenticated with `repo` scope). See .planning/phases/02-core-execution-agents/02-FIXTURE-REPO.md
# HSB_TEST_FIXTURE_URL=https://github.com/<YOUR_GITHUB_USER>/hsb-test-fixture

# Optional: PAT for non-interactive GitHub auth. If set, `make auth-github`
# uses `gh auth login --with-token` instead of the interactive device flow.
# Token must have `repo` scope. Persisted to the hsb-gh-auth named volume.
# GITHUB_TOKEN=ghp_your_personal_access_token_here
